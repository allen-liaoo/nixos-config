{
	http_port 80
	https_port 443

	servers {
		trusted_proxies static 10.0.0.1/32
	}
}

# Common settings shared by all HTTPS virtual hosts.
(common) {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}

	encode zstd gzip

	header {
		X-XSS-Protection "1; mode=block"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
		level WARN
	}
}

# Shared reverse_proxy transport behavior.
(proxy_transport) {
	transport http {
		dial_timeout 360s
		read_timeout 360s
		write_timeout 360s
	}
}

# Authelia authorization for protected services.
(authelia_protect) {
	forward_auth http://host.containers.internal:9080 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

{$DOMAIN}, *.{$DOMAIN} {
	import common

	@www host www.{$DOMAIN}
	redir @www https://{$DOMAIN}{uri} permanent

	@apex host {$DOMAIN}
	redir @apex https://blog.{$DOMAIN}{uri} permanent

	@blog host blog.{$DOMAIN}
	handle @blog {
		root * /srv/alsblog

		@hidden path_regexp hidden (^|/)\.
		respond @hidden 403

		@static path_regexp static \.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot|webp|avif)$
		header @static Cache-Control "public, immutable"

		#try_files {path} {path}/ =404.html
		file_server
	}

	@auth host auth.{$DOMAIN}
	handle @auth {
		reverse_proxy http://host.containers.internal:9080 {
			import proxy_transport
		}
	}

